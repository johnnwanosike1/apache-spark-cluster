# =============================================================================
# Environment variables for spark-cluster
# Copy this file to .env and adjust as needed:
#     cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Gluten/Velox toggle
#   false  → vanilla JVM Spark (default)
#   true   → enable Gluten/Velox native acceleration
#            NOTE: Gluten 1.4.x targets Spark 3.5. On Spark 4.1.1 some
#            operators will fall back to JVM — safe and expected.
# ---------------------------------------------------------------------------
GLUTEN_ENABLED=false

# ---------------------------------------------------------------------------
# Worker resources (applied to both workers)
# ---------------------------------------------------------------------------
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# ---------------------------------------------------------------------------
# JupyterLab access token
# ---------------------------------------------------------------------------
JUPYTER_TOKEN=spark
