# Environment variables for spark-cluster (Spark 4.0.2 + Gluten 1.6.0)
# Copy to .env:  cp .env.example .env

# Gluten/Velox toggle
#   false  → vanilla JVM Spark (default)
#   true   → Gluten 1.6.0 + Velox (supports Spark 4.0.x / Scala 2.13)
GLUTEN_ENABLED=false

# Worker resources
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# JupyterLab token
JUPYTER_TOKEN=spark


