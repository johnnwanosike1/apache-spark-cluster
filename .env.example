# Environment variables for spark-cluster (Spark 3.5.8)
# Copy to .env:  cp .env.example .env

# Gluten/Velox toggle
#   false  → vanilla JVM Spark (default)
#   true   → Gluten 1.6.0 + Velox (fully compatible with Spark 3.5 / Scala 2.12)
GLUTEN_ENABLED=false

# Worker resources
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# JupyterLab token
JUPYTER_TOKEN=spark
